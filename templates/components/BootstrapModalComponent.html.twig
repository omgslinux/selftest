{# templates/components/bootstrap_modal.html.twig #}

<div {{ attributes }}>
    {# Modal Backdrop #}
    <div class="modal-backdrop fade {{ isOpen ? 'show' : '' }}"
         style="{{ isOpen ? 'display: block;' : 'display: none;' }}"></div>

    {# Modal Dialog #}
    <div class="modal fade {{ isOpen ? 'show d-block' : '' }}"
         id="{{ modalId }}"
         tabindex="-1"
         aria-labelledby="{{ modalId }}Label"
         aria-hidden="{{ isOpen ? 'false' : 'true' }}"
         {% if staticBackdrop %}data-bs-backdrop="static" data-bs-keyboard="false"{% endif %}>
        <div class="modal-dialog modal-{{ size }} {% if scrollable %}modal-dialog-scrollable{% endif %}">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="{{ modalId }}Label">{{ title }}</h5>
                    <button type="button"
                            class="btn-close"
                            data-action="live#action"
                            data-action-name="close()"
                            aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    {% block modal_body %}
                        {# El contenido del modal se inyectará aquí #}
                    {% endblock %}
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-action="live#action"
                            data-action-name="close()">
                        {{ closeText }}
                    </button>

                    {% block modal_footer %}
                        {# Acciones adicionales se pueden inyectar aquí #}
                    {% endblock %}
                </div>
            </div>
        </div>
    </div>
</div>
