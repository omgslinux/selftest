<div {{ attributes }}>
    <div class="row border bg-secondary">
        <div class="col-1">Id</div>
        <div class="col-5">Texto</div>
        <div class="col-1">Activa</div>
        <div class="col-1">Respuestas</div>
        <div class="col-4 text-center">Acciones</div>
    </div>
    {% for question in this.all %}
        <div class="row border">
            <div class="col-1">{{ question.id }}</div>
            <div class="col-5">{{ question.text }}</div>
            <div class="col-1">{{ question.active }}</div>
            <div class="col-1">{{ question.answers|length }}</div>
            <div class="col-4 d-flex justify-content-evenly">
                <div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#{{ tagPrefix ~ modalId }}Modal" {{ live_action('edit', {'id': question.id}) }}>Editar</button>
                </div>
                <div>
                    <form method="post" {{ live_action('delete', {'id': question.id}) }} onclick="return confirm('Are you sure you want to delete this item?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                        <button class="btn btn-danger">Borrar</button>
                    </form>
                </div>
            </div>
        </div>
    {% endfor %}
    <p>Registros: {{ this.all|length }}</p>
    {# Botón para crear un nuevo registro #}
    <button class="px-4 py-2 text-white btn btn-primary rounded" data-bs-toggle="modal" data-bs-target="#{{ tagPrefix ~ modalId }}Modal" {{ live_action("new") }}>Create {{ itemName }}</button>

    {{ form_start(form, {
    attr: {
    'data-action': 'live#action:prevent',
    'data-live-action-param': 'save'
    }
    }) }}
    <twig:ModalComponent modalId="{{ modalId }}" button="0" modalTitle="{{ (this.id != null) ? 'Edit ' : 'Create ' ~ itemName }}" modalSize="modal-lg" tagPrefix="{{ tagPrefix }}">
            {{ form_row(form.text) }}
            {{ form_errors(form.text) }}
            {{ form_row(form.active) }}

        <twig:block name="footer">
            {{ parent() }}
        </twig:block>
    </twig:ModalComponent>
    {{ form_end(form) }}

</div>
