{# templates/components/QuestionCrudComponent.html.twig #}

<div {{ attributes }}>
    {# Listado principal - Se atenúa cuando el modal está abierto #}
    <div class="{{ modalMode != 'none' ? 'opacity-25 pe-none' : '' }}">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Questions</h2>
            <button class="btn btn-primary"
                    {{ live_action("newQuestion()")}}>
                <i class="bi bi-plus-circle me-2"></i>New Question
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Text</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for question in this.questions %}
                        <tr>
                            <td>{{ question.text }}</td>
                            <td>
                                <span class="badge bg-{{ question.active ? 'success' : 'secondary' }}">
                                    {{ question.active ? 'Active' : 'Inactive' }}
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-primary"
                                            {{ live_action('showQuestion', { 'entity': question.id }) }}">
                                        <i class="bi bi-eye">show</i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning"
                                            {{ live_action('editQuestion', { 'entity': question.id }) }}">
                                        <i class="bi bi-pencil">edit</i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            {{ live_action('deleteQuestion', { 'entity': question.id }) }}"
                                            onclick="return confirm('Delete this question?')">
                                        <i class="bi bi-trash">delete</i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                No questions found
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Paginación mejorada #}
        {% set totalPages = (this.totalQuestions / itemsPerPage)|round(0, 'ceil') %}
        {% if totalPages > 1 %}
            <nav aria-label="Question pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item {{ page == 1 ? 'disabled' : '' }}">
                        <button class="page-link"
                                data-action-name="$set('page', {{ page - 1 }})}}">
                            Previous
                        </button>
                    </li>

                    {% for i in 1..totalPages %}
                        <li class="page-item {{ i == page ? 'active' : '' }}">
                            <button class="page-link"
                                    data-action="live#action"
                                    data-action-name="$set('page', {{ i }})">
                                {{ i }}
                            </button>
                        </li>
                    {% endfor %}

                    <li class="page-item {{ page == totalPages ? 'disabled' : '' }}">
                        <button class="page-link"
                                data-action="live#action"
                                data-action-name="$set('page', {{ page + 1 }})">
                            Next
                        </button>
                    </li>
                </ul>
            </nav>
        {% endif %}
    </div>

    {# Modal de CRUD #}
    {% if modalMode != 'none' %}
        <div class="modal-overlay">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content shadow-lg">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">
                            {% if modalMode == 'show' %}
                                <i class="bi bi-eye-fill me-2"></i>View Question
                            {% elseif modalMode == 'edit' %}
                                <i class="bi bi-pencil-fill me-2"></i>Edit Question
                            {% else %}
                                <i class="bi bi-plus-circle-fill me-2"></i>New Question
                            {% endif %}
                        </h5>
                        <button type="button"
                                class="btn-close btn-close-white"
                                data-action="live#action"
                                data-action-name="closeModal()"
                                aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        {% if modalMode == 'show' %}
                            <div class="mb-3">
                                <label class="form-label fw-bold">Question Text:</label>
                                <p class="form-control-static">{{ this.currentQuestion.text }}</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Status:</label>
                                <p class="form-control-static">
                                    <span class="badge bg-{{ this.currentQuestion.active ? 'success' : 'secondary' }}">
                                        {{ this.currentQuestion.active ? 'Active' : 'Inactive' }}
                                    </span>
                                </p>
                            </div>
                        {% else %}
                            {{ form_start(this.form) }}
                                {{ form_row(this.form.text, {
                                    'attr': {'class': 'form-control-lg'},
                                    'label_attr': {'class': 'fw-bold'}
                                }) }}

                                {{ form_row(this.form.active, {
                                    'attr': {'class': 'form-check-input-lg'},
                                    'label_attr': {'class': 'form-check-label fw-bold'}
                                }) }}

                                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                                    <button type="button"
                                            class="btn btn-secondary me-md-2"
                                            data-action="live#action"
                                            data-action-name="closeModal()">
                                        Cancel
                                    </button>
                                    <button type="submit"
                                            class="btn btn-primary"
                                            data-action="live#action"
                                            data-action-name="saveQuestion()">
                                        Save Changes
                                    </button>
                                </div>
                            {{ form_end(this.form) }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1050;
    }
    .form-control-static {
        padding: 0.375rem 0;
        margin-bottom: 0;
        line-height: 1.5;
        background-color: transparent;
        border: solid transparent;
        border-width: 1px 0;
    }
    .form-check-input-lg {
        width: 1.2rem;
        height: 1.2rem;
        margin-top: 0.1rem;
    }
</style>
