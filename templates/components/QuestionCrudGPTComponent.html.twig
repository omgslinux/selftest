{% extends 'base.html.twig' %}

{% block title %}Gestión de Preguntas{% endblock %}

{% block body %}
    <h1>Gestión de Preguntas</h1>

    <div class="d-flex justify-content-between mb-3">
        <h2>Listado de preguntas</h2>
        <button class="btn btn-primary" wire:click="openModal">
            Añadir nueva pregunta
        </button>
    </div>

    <ul class="list-group">
        {% for question in questions %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                {{ question.text }}
                <div>
                    <a href="#" class="btn btn-sm btn-info" wire:click="openModal({{ question.id }})">
                        Editar
                    </a>
                    <a href="#" class="btn btn-sm btn-danger" wire:click="delete({{ question.id }})">Eliminar</a>
                </div>
            </li>
        {% else %}
            <p>No hay preguntas disponibles.</p>
        {% endfor %}
    </ul>

    {# Modal para crear y editar preguntas con bloques de contenido #}
