{% extends 'base.html.twig' %}

{% block title %}Question index{% endblock %}

{% block body %}
    <h1>Question index</h1>

    {% set modalTarget = targetPrefix ~ "Modal" %}
    <div class="row border bg-secondary">
        <div class="col-1">Id</div>
        <div class="col-5">Texto</div>
        <div class="col-1">Activa</div>
        <div class="col-1">Respuestas</div>
        <div class="col-4 text-center">Acciones</div>
    </div>
    {% for question in questions %}
        <div class="row border">
            <div class="col-1">{{ question.id }}</div>
            <div class="col-5">{{ question.text }}</div>
            <div class="col-1">{{ question.active }}</div>
            <div class="col-1">{{ question.answers|length }}</div>
            <div class="col-4 d-flex justify-content-evenly">
                <div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#{{ modalTarget }}" data-url="{{ path(PREFIX ~ 'edit', {'id': question.id}) }}">Editar</button>
                </div>
                <div>
                    <form method="post" action="{{ path(PREFIX ~ 'delete', {'id': question.id}) }}" onclick="return confirm('Are you sure you want to delete this item?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                        <button class="btn btn-danger">Borrar</button>
                    </form>
                </div>
            </div>
        </div>
    {% endfor %}
    <p>Registros: {{ questions|length }}</p>
    {# Botón para crear un nuevo registro #}
    <button class="px-4 py-2 text-white btn btn-primary rounded" data-bs-toggle="modal" data-bs-target="#{{ modalTarget }}" data-url="{{ path(PREFIX ~ "new") }}">Create question</button>
    {% set modalTitle = 'Edit question' %}
    {{ include('_modal.html.twig', {
      'nobutton': true,
      'targetPrefix': targetPrefix,
      'VARS': VARS
      })
    }}

    <script>
    document.body.addEventListener('click', function(e) {
        //console.log('Entrmos en click');
        if (e.target.classList.contains('add-row')) {
            # Buscar estructura en _form.html.twig
            const collectionHolder = document.querySelector('.answer-row-collection');
            console.log('Vamos a add-row');
        const prototype = collectionHolder.dataset.prototype;
        const index = collectionHolder.dataset.index;

        const newForm = prototype.replace(/__nane__/g, index);
        collectionHolder.dataset.index = parseInt(index) + 1;

        const item = document.createElement('div');
        item.innerHTML = newForm;
        collectionHolder.appendChild(item);

        // Añadir evento al botón de eliminar del nuevo elemento
        item.querySelector('.remove-row').addEventListener('click', function() {
            this.closest('.answer-row-container').remove();
        });
        }
    });
    </script>


{% endblock %}
