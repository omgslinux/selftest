{% extends 'base.html.twig' %}

{% block title %}SelfTest - Inicio{% endblock %}

{% block body %}
    <nav class="navbar navbar-expand-lg sticky-top bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-brain me-2"></i>
                SelfTest
            </a>
            <div class="d-flex align-items-center gap-3">
                {% if is_granted('ROLE_TEACHER') %}
                <a href="{{ path('admin') }}" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-cog"></i>
                </a>
                {% endif %}
                <div class="user-info">
                    <div class="user-avatar">
                        {{ app.user.name|first|upper }}
                    </div>
                    <span class="fw-semibold">{{ app.user.name }}</span>
                </div>
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title">¡Bienvenido, {{ app.user.name }}!</h1>
            <p class="hero-subtitle">Selecciona un cuestionario para comenzar</p>
            
            {% if quizzesData %}
                <div class="row g-4">
                    {% for item in quizzesData %}
                        <div class="col-md-6 col-lg-4">
                            <div class="quiz-card">
                                <div class="quiz-icon {% if item.completed %}green{% else %}purple{% endif %}">
                                    <i class="fas {% if item.completed %}fa-check{% else %}fa-clipboard-list{% endif %}"></i>
                                </div>
                                <h4>{{ item.quiz.name }}</h4>
                                <div class="quiz-meta">
                                    <span><i class="fas fa-folder"></i> {{ item.quiz.topic.category.name }}</span>
                                    <span><i class="fas fa-tag"></i> {{ item.quiz.topic.name }}</span>
                                    <span><i class="fas fa-signal"></i> {{ item.quiz.level.name }}</span>
                                </div>
                                <p>{{ item.questionCount }} preguntas</p>
                                
                                {% if item.completed %}
                                    <div class="d-flex gap-2">
                                        <a href="{{ path('app_quiz_result', {id: item.testId}) }}" class="btn-start flex-fill">
                                            <i class="fas fa-eye me-2"></i>
                                            Ver resultados
                                        </a>
                                        <a href="{{ path('app_quiz_start', {id: item.quiz.id}) }}" class="btn-start flex-fill">
                                            <i class="fas fa-redo me-2"></i>
                                            Repetir
                                        </a>
                                    </div>
                                {% else %}
                                    <a href="{{ path('app_quiz_start', {id: item.quiz.id}) }}" class="btn-start">
                                        <i class="fas fa-play me-2"></i>
                                        Comenzar
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    No hay cuestionarios disponibles actualmente.
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
