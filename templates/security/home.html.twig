{% extends 'base.html.twig' %}

{% block title %}SelfTest - Inicio{% endblock %}

{% block body %}
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title">¡Bienvenido, {{ app.user.name }}!</h1>
            <p class="hero-subtitle">Selecciona un cuestionario para comenzar</p>
            
            <div class="filter-bar mb-4 p-3 bg-white rounded shadow-sm">
                <form method="get" action="{{ path('app_home') }}" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label for="category" class="form-label small fw-semibold">Categoría</label>
                        <select name="category" id="category" class="form-select">
                            <option value="">Todas las categorías</option>
                            {% for category in categories %}
                                <option value="{{ category.id }}" {% if selectedCategory == category.id %}selected{% endif %}>
                                    {{ category.name|replace({'AZ900': 'AZ-900'}) }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="level" class="form-label small fw-semibold">Nivel</label>
                        <select name="level" id="level" class="form-select">
                            <option value="">Todos los niveles</option>
                            {% for level in levels %}
                                <option value="{{ level.id }}" {% if selectedLevel == level.id %}selected{% endif %}>
                                    {{ level.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="status" class="form-label small fw-semibold">Estado</label>
                        <select name="status" id="status" class="form-select">
                            <option value="">Todos</option>
                            <option value="pending" {% if selectedStatus == 'pending' %}selected{% endif %}>Sin hacer</option>
                            <option value="completed" {% if selectedStatus == 'completed' %}selected{% endif %}>Completados</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter me-2"></i>
                            Filtrar
                        </button>
                    </div>
                </form>
                {% if selectedCategory or selectedLevel or selectedStatus %}
                <div class="mt-2">
                    <a href="{{ path('app_home', {clear: 1}) }}" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-times me-1"></i>
                        Limpiar filtros
                    </a>
                </div>
                {% endif %}
            </div>
            
            {% if quizzesData %}
                <div class="row g-4">
                    {% for item in quizzesData %}
                        {% set colors = ['purple', 'blue', 'green', 'orange', 'red', 'teal', 'pink', 'indigo'] %}
                        {% set color = colors[loop.index0 % colors|length] %}
                        <div class="col-md-6 col-lg-4">
                            <div class="quiz-card" style="background: linear-gradient(135deg, {% if item.quiz.level.name == 'Básico' %}#d1fae5{% elseif item.quiz.level.name == 'Intermedio' %}#fef3c7{% else %}#fee2e2{% endif %} 0%, {% if item.quiz.level.name == 'Básico' %}#a7f3d0{% elseif item.quiz.level.name == 'Intermedio' %}#fde68a{% else %}#fecaca{% endif %} 100%);">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="quiz-icon {% if item.completed %}green{% else %}{% if item.quiz.level.name == 'Básico' %}green{% elseif item.quiz.level.name == 'Intermedio' %}orange{% else %}red{% endif %}{% endif %}">
                                        <i class="fas {% if item.completed %}fa-check{% else %}fa-clipboard-list{% endif %}"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4 style="color: #1a1a2e; margin-bottom: 4px;">{{ item.quiz.name }}</h4>
                                        <p class="mb-1" style="font-size: 12px; color: #4b5563;">{{ item.quiz.topic.category.name|replace({'AZ900': 'AZ-900'}) }}</p>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-{% if item.quiz.level.name == 'Básico' %}success{% elseif item.quiz.level.name == 'Intermedio' %}warning{% else %}danger{% endif %}" style="font-size: 11px;">{{ item.quiz.level.name }}</span>
                                            <span style="font-size: 12px; color: #4b5563;">{{ item.questionCount }} preg.</span>
                                            {% if item.completed and item.score is not null %}
                                                <span class="badge bg-{% if item.score >= 70 %}success{% elseif item.score >= 50 %}warning{% else %}danger{% endif %}" style="font-size: 12px; margin-left: auto;">
                                                    <i class="fas fa-star me-1"></i>{{ item.score }}%
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                
                                {% if item.completed %}
                                    <div class="d-flex gap-2 mt-3">
                                        <a href="{{ path('app_quiz_result', {id: item.testId}) }}" class="btn-start flex-fill">
                                            <i class="fas fa-eye me-2"></i>
                                            Ver resultados
                                        </a>
                                        <a href="{{ path('app_quiz_start', {id: item.quiz.id}) }}" class="btn-start flex-fill">
                                            <i class="fas fa-redo me-2"></i>
                                            Repetir
                                        </a>
                                    </div>
                                    <div class="text-center mt-2">
                                        <span class="badge bg-{% if item.score >= 70 %}success{% elseif item.score >= 50 %}warning{% else %}danger{% endif %}" style="font-size: 14px; padding: 8px 16px;">
                                            <i class="fas fa-trophy me-1"></i>Puntuación: {{ item.score }}%
                                        </span>
                                    </div>
                                {% else %}
                                    <a href="{{ path('app_quiz_start', {id: item.quiz.id}) }}" class="btn-start">
                                        <i class="fas fa-play me-2"></i>
                                        Comenzar
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    No hay cuestionarios disponibles actualmente.
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
