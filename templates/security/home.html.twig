<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SelfTest - Inicio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-brain me-2"></i>
                SelfTest
            </a>
            <div class="d-flex align-items-center gap-3">
                <div class="user-info">
                    <div class="user-avatar">
                        {{ app.user.name|first|upper }}
                    </div>
                    <span class="fw-semibold">{{ app.user.name }}</span>
                </div>
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title">¡Bienvenido, {{ app.user.name }}!</h1>
            <p class="hero-subtitle">Selecciona un cuestionario para comenzar</p>
            
            {% if quizzes %}
                <div class="row g-4">
                    {% for quiz in quizzes %}
                        <div class="col-md-6 col-lg-4">
                            <div class="quiz-card" onclick="window.location='{{ path('app_quiz_start', {id: quiz.id}) }}'">
                                <div class="quiz-icon purple">
                                    <i class="fas fa-clipboard-list"></i>
                                </div>
                                <h4>{{ quiz.name }}</h4>
                                <div class="quiz-meta">
                                    <span><i class="fas fa-folder"></i> {{ quiz.topic.category.name }}</span>
                                    <span><i class="fas fa-tag"></i> {{ quiz.topic.name }}</span>
                                    <span><i class="fas fa-signal"></i> {{ quiz.level.name }}</span>
                                </div>
                                <p>{{ quiz.questions|length }} preguntas</p>
                                <div class="btn-start">
                                    <i class="fas fa-play me-2"></i>
                                    Comenzar
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    No hay cuestionarios disponibles actualmente.
                </div>
            {% endif %}
        </div>
    </section>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
