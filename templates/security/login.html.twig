{% extends 'base.html.twig' %}

{% block title %}SelfTest - Iniciar Sesión{% endblock %}

{% block body %}
    <div class="bg-gradient min-vh-100 d-flex align-items-center justify-content-center p-4">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        
        <div class="login-container">
            <div class="login-card">
                <div class="brand">
                    <div class="brand-icon">
                        <i class="fas fa-brain"></i>
                    </div>
                    <h1>SelfTest</h1>
                    <p>Tu plataforma de aprendizaje</p>
                </div>
                
                {% if error %}
                    <div class="error-message">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                    </div>
                {% endif %}
                
                <form method="post">
                    <div class="mb-4">
                        <label for="username" class="form-label fw-semibold">
                            <i class="fas fa-user me-2"></i>Usuario
                        </label>
                        <input type="text" class="form-control form-control-lg" id="username" name="_username" value="{{ last_username }}" placeholder="Introduce tu usuario" required autofocus>
                    </div>
                    
                    <div class="mb-4">
                        <label for="password" class="form-label fw-semibold">
                            <i class="fas fa-lock me-2"></i>Contraseña
                        </label>
                        <input type="password" class="form-control form-control-lg" id="password" name="_password" placeholder="Introduce tu contraseña" required>
                    </div>
                    
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="{{ path('app_home') }}">
                    
                    <button class="btn-login" type="submit">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Iniciar Sesión
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
